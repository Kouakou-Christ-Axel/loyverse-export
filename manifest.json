{
  "manifest_version": 3,
  "name": "Loyverse Receipts Exporter",
  "version": "1.0.0",
  "description": "Exporte les reçus Loyverse en CSV ou JSON, uniquement lorsque vous êtes connecté à r.loyverse.com.",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": ["https://r.loyverse.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Loyverse Receipts Exporter",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://r.loyverse.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
